<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Summary Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:id="@+id/tvSummaryHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="10dp"/>
                <TextView android:id="@+id/tvTotalImages"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="?attr/colorOnSurface" android:textSize="13sp"/>
                <TextView android:id="@+id/tvTotalDets"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="?attr/colorOnSurface" android:textSize="13sp"/>
                <TextView android:id="@+id/tvTotalGTs"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="?attr/colorOnSurface" android:textSize="13sp"
                    android:layout_marginBottom="10dp"/>
                <TextView android:id="@+id/tvPrecision"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="?attr/colorOnSurface" android:textSize="13sp"
                    android:fontFamily="monospace"/>
                <TextView android:id="@+id/tvRecall"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="?attr/colorOnSurface" android:textSize="13sp"
                    android:fontFamily="monospace"/>
                <TextView android:id="@+id/tvAccuracy"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="?attr/colorOnSurface" android:textSize="13sp"
                    android:fontFamily="monospace"/>
                <TextView android:id="@+id/tvF1"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="?attr/colorOnSurface" android:textSize="13sp"
                    android:fontFamily="monospace"/>
                <TextView android:id="@+id/tvMap50"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="?attr/colorOnSurface" android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="10dp"/>
                <TextView android:id="@+id/tvInfMean"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="?attr/colorOnSurfaceVariant" android:textSize="13sp"
                    android:fontFamily="monospace"/>
                <TextView android:id="@+id/tvInfMin"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="?attr/colorOnSurfaceVariant" android:textSize="13sp"
                    android:fontFamily="monospace"/>
                <TextView android:id="@+id/tvInfMax"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="?attr/colorOnSurfaceVariant" android:textSize="13sp"
                    android:fontFamily="monospace"/>
                <TextView android:id="@+id/tvInfStd"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="?attr/colorOnSurfaceVariant" android:textSize="13sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Bar Chart Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Per-Class Performance"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="8dp"/>
                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/barChart"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Per-Class Table Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Per-Class Breakdown"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="8dp"/>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvPerClass"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Confusion Matrix Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Normalized Confusion Matrix"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rows = Actual · Columns = Predicted · Pinch to zoom · Drag to pan"
                    android:textSize="11sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="12dp"/>
                <com.fsl.detector.ui.ConfusionMatrixView
                    android:id="@+id/confusionMatrixView"
                    android:layout_width="match_parent"
                    android:layout_height="420dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>