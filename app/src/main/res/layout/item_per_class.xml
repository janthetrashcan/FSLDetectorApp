<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="6dp"
    android:background="?android:attr/selectableItemBackground">

    <TextView android:id="@+id/tvClass"
        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2"
        android:textSize="12sp" android:textStyle="bold" android:textColor="#1A237E"/>
    <TextView android:id="@+id/tvTP"
        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.7"
        android:textSize="11sp" android:gravity="center" android:fontFamily="monospace"/>
    <TextView android:id="@+id/tvFP"
        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.7"
        android:textSize="11sp" android:gravity="center" android:fontFamily="monospace"/>
    <TextView android:id="@+id/tvFN"
        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.7"
        android:textSize="11sp" android:gravity="center" android:fontFamily="monospace"/>
    <TextView android:id="@+id/tvPrecision"
        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
        android:textSize="11sp" android:gravity="center" android:fontFamily="monospace"/>
    <TextView android:id="@+id/tvRecall"
        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
        android:textSize="11sp" android:gravity="center" android:fontFamily="monospace"/>
    <TextView android:id="@+id/tvF1"
        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
        android:textSize="11sp" android:gravity="center" android:textStyle="bold" android:fontFamily="monospace"/>
    <TextView android:id="@+id/tvAP"
        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
        android:textSize="11sp" android:gravity="center" android:fontFamily="monospace"/>
</LinearLayout>
